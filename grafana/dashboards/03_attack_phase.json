      "datasource": { "type": "prometheus", "uid": "ffq2ixds39wjkc" },
      "targets": [{ "expr": "sum by (phase, cloud_provider) (security_predicted_phase_total{cloud_provider=~\"$cloud_provider\"})", "legendFormat": "{{phase}} / {{cloud_provider}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" },
          "custom": { "scaleDistribution": { "type": "log", "log": 10 } } }, "overrides": [
        { "matcher": { "id": "byRegexp", "options": "^Normal" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
        { "matcher": { "id": "byRegexp", "options": "^Reconnaissance" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
        { "matcher": { "id": "byRegexp", "options": "^CredentialCreation" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
        { "matcher": { "id": "byRegexp", "options": "^SuspiciousLogin" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-orange" } }] },
        { "matcher": { "id": "byRegexp", "options": "^SuspiciousServiceAccountCreation" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] },
        { "matcher": { "id": "byRegexp", "options": "^DefenseEvasion" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-purple" } }] },
        { "matcher": { "id": "byRegexp", "options": "^BruteForce" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] },
        { "matcher": { "id": "byRegexp", "options": "^PrivilegeEscalation" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
        { "matcher": { "id": "byRegexp", "options": "^UnauthorizedAccessAttempt" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-red" } }] },
        { "matcher": { "id": "byRegexp", "options": "^AccountCompromised" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] }
      ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "orientation": "auto" }
    },
